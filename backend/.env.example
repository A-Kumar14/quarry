# OpenRouter — required
OPENROUTER_API_KEY=your-openrouter-key-here

# Default model (optional — falls back to openai/gpt-4o)
# OPENROUTER_CHAT_MODEL=openai/gpt-4o

# Comma-separated list of allowed CORS origins (default: * for dev)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Auth (set JWT_SECRET to enable login protection) ──────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=your-secret-here

# How long tokens last (default: 30 days)
# JWT_EXPIRE_DAYS=30

# Dev bypass: if set, requests with this exact token skip JWT verification.
# Lets you use the app locally without logging in every time.
# Set REACT_APP_DEV_TOKEN to the same value in frontend/.env
# DEV_BYPASS_TOKEN=your-dev-token-here
