# Set AI_PROVIDER to one of: openrouter, openai, gemini
# If not set, it auto-detects from which API key is present.
AI_PROVIDER=openrouter

# OpenRouter (recommended — access to GPT-4o, Grok, Claude, Gemini, etc.)
OPENROUTER_API_KEY=your-openrouter-key-here

# OpenAI (alternative)
# OPENAI_API_KEY=your-openai-key-here

# Gemini (alternative)
# GOOGLE_API_KEY=your-google-api-key-here

# ScrapingBee — used for Google Images search (Images tab)
# Get your key at https://scrapingbee.com (free trial available)
# SCRAPINGBEE_API_KEY=your-scrapingbee-key-here

# Comma-separated list of allowed CORS origins (default: * for dev)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
